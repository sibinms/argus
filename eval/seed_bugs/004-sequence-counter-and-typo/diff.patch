+"""
+Management command: backfill_payout_sequence_numbers
+
+Assigns sequential, per-merchant payout IDs (reference_id) to all
+existing Payout records that don't yet have one.
+
+Payouts for each business are numbered chronologically:
+  - primary sort: completed_at ASC  (None values sorted last)
+  - secondary sort: id ASC          (tie-break within the same completed_at)
+
+After numbering, the django-sequences counter for each business is set to the
+maximum assigned value so that new payouts created via Payout.save() continue
+the sequence without gaps or collisions.
+
+Usage:
+    python manage.py backfill_payout_sequence_numbers
+    python manage.py backfill_payout_sequence_numbers --dry-run
+"""
+
+from django.core.management.base import BaseCommand
+from django.db import transaction
+from sequences.models import Sequence as SequenceRecord
+
+from payments.models import Payout
+
+
+class Command(BaseCommand):
+    help = "Backfill reference_id on Payout records"
+
+    def add_arguments(self, parser):
+        parser.add_argument(
+            "--dry-run",
+            action="store_true",
+            help="Print what would be done without writing to the DB",
+        )
+
+    def handle(self, *args, **options):
+        dry_run = options["dry_run"]
+
+        # All distinct businesses that have at least one unnumbered payout.
+        business_ids = list(
+            Payout.objects.filter(reference_id__isnull=True)
+            .values_list("business_id", flat=True)
+            .distinct()
+            .order_by("business_id")
+        )
+
+        if not business_ids:
+            self.stdout.write("No payouts need backfilling.")
+            return
+
+        total_updated = 0
+
+        for business_id in business_ids:
+            payouts = list(
+                Payout.objects.filter(
+                    business_id=business_id,
+                    reference_id__isnull=True,
+                )
+                # NULLs last so incomplete payouts go after completed ones.
+                .extra(
+                    select={"completed_at_is_null": "completed_at IS NULL"},
+                    order_by=["completed_at_is_null", "completed_at", "id"],
+                )
+            )
+
+            if not payouts:
+                continue
+
+            for idx, payout in enumerate(payouts, start=1):
+                payout.reference_id = idx
+
+            if dry_run:
+                self.stdout.write(
+                    f"[DRY RUN] Business {business_id}: "
+                    f"would assign 1–{len(payouts)} to {len(payouts)} payout(s)"
+                )
+                continue
+
+            max_seq = len(payouts)
+
+            with transaction.atomic():
+                Payout.objects.bulk_update(payouts, ["reference_id"])
+                # Advance the django-sequences counter so Payout.save() continues
+                # from max_seq + 1 for future payouts.
+                SequenceRecord.objects.update_or_create(
+                    name=f"payout-{business_id}",
+                    defaults={"last": max_seq},
+                )
+
+            total_updated += max_seq
+            self.stdout.write(
+                f"Business {business_id}: assigned 1–{max_seq} ({max_seq} payout(s))"
+            )
+
+        if not dry_run:
+            self.stdout.write(
+                self.style.SUCCESS(
+                    f"Done. {total_updated} payout(s) backfilled across "
+                    f"{len(business_ids)} business(es)."
+                )
+            )

+def _payout_slot(payout_cycle):
+    """Map the generation cycle to a payout slot.
+
+    Membership pays twice a day: the morning (9am GST) cron fires with cycle
+    "first", the evening (4pm GST) cron with "second". Every other payout
+    (standard next-day, closing, admin-forced) is ad-hoc.
+    """
+    if payout_cycle == "first":
+        return Payout.SLOT.morning
+    if payout_cycle == "second":
+        return Payout.SLOT.evening
+    return Payout.SLOT.adhoc
+

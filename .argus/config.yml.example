# Copy this file to .argus/config.yml and adjust for your repo.

# active: posts inline comments + a verdict on the pull request (the default)
# shadow: never posts, only writes a report (see `posting.shadow`) — use this
#         while you're building trust in a new repo or a new set of lenses
mode: active

# Any provider litellm supports works here — mix providers freely, e.g.
# lens: gpt-4o-mini with curator: claude-opus-4-8. Set whichever provider's
# API key as an env var (ANTHROPIC_API_KEY, OPENAI_API_KEY, GEMINI_API_KEY,
# OPENROUTER_API_KEY, ...): https://docs.litellm.ai/docs/providers
models:
  lens: claude-haiku-4-5      # cheap, high-volume — asked to over-report
  curator: claude-opus-4-8     # expensive, precise — can only drop a finding by citing evidence
  # lens: gpt-4o-mini
  # curator: gpt-4o
  # lens: gemini/gemini-1.5-flash
  # curator: gemini/gemini-1.5-pro
  # OpenRouter — one key, hundreds of models. Prefix the model with openrouter/
  # and set OPENROUTER_API_KEY:
  # lens: openrouter/anthropic/claude-3.5-haiku
  # curator: openrouter/anthropic/claude-3.5-sonnet

# Built-in lenses: security, tests, error_handling, contracts
# Add your own by pointing at a markdown file, see docs/writing-a-lens.md
lenses:
  - security
  - tests
  - error_handling
  - contracts
  # - custom: .argus/lenses/payment-safety.md

context:
  max_files: 15
  max_bytes_per_file: 20000
  include_neighbors: false   # off by default — usage context caused false reassurance in testing
  ignore_globs:
    - "*.lock"
    - "*.min.js"
    - "*/migrations/*"

posting:
  min_confidence: medium   # low | medium | high
  show_dropped_reasoning: true
